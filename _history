"preferredEditor\": \"tsprj\",\n    \"languageRestriction\": \"javascript-only\",\n    \"additionalFilePaths\": []\n}\n"}},{"timestamp":1773153395534,"editorVersion":"4.0.10","text":{"main.ts":"","README.md":" ","assets.json":"","polyrosary.ts":"// more events\n/*\nOn tick every [x] update, \nConfig library, using browser events to open a new menu!!!\n\n*/\n\nenum ConfigType {\n    INT,\n    BOOL,\n    TOGGLE,\n    SINGLEUSE\n}\n\nclass ConfigOption {\n    _str: string;\n    _typ: ConfigType;\n    _bsV: any;\n    _state: any;\n\n    constructor(name: string, configType: ConfigType, baseValue: any) {\n        this._str = name;\n        this._typ = configType;\n        this._bsV = baseValue;\n        this._state = baseValue;\n    }\n}\n\nclass Config {\n    _configs: ConfigOption[];\n    _title: string;\n\n    constructor(title: string, configs?: ConfigOption[]) {\n        this._configs = configs;\n        this._title = title;\n    }\n}\n\nfunction registerConfig(name: string, configs?: ConfigOption[]): Config {\n    const createdConfig = new Config(name, configs);\n    return createdConfig;\n}\n\nfunction createConfigOption(name: string, configType: ConfigType, baseValue: any): ConfigOption {\n    const createdConfigOption = new ConfigOption(name, configType, baseValue);\n\n    return createdConfigOption;\n}\n\nlet configTest: Config = registerConfig(\"test\");\n\nlet configOptionTest1: ConfigOption = createConfigOption(\"configOptionTest1\", ConfigType.BOOL, false);\nconfigTest._configs.push(configOptionTest1);","pxt.json":"{\n    \"name\": \"Polyrosary\",\n    \"description\": \"\",\n    \"dependencies\": {\n        \"device\": \"*\",\n        \"browser-events\": \"*\"\n    },\n    \"files\": [\n        \"main.ts\",\n        \"README.md\",\n        \"assets.json\",\n        \"polyrosary.ts\"\n    ],\n    \"preferredEditor\": \"tsprj\",\n    \"languageRestriction\": \"javascript-only\"\n}\n"}},{"timestamp":1773155197884,"editorVersion":"4.0.10","text":{"main.ts":"","README.md":" ","assets.json":"","polyrosary.ts":"/*\nMultiple\nTick events, a loader system that will run a function at an interval\nloader can run 'bootstrap' and begin ticking its function at the interval.\n*/\n\nenum Inputs {\n\n}\n\nfunction programName(): string {\n    return \"(\" + control.programName() + \")\";\n}\n\nclass TickingLoader {\n    _interval: number;\n    _event: Function;\n\n    constructor(tickInterval: number, event: Function) {\n        this._interval = tickInterval;\n        this._event = event;\n    }\n\n    get tickInterval(): number {\n        return this._interval;\n    }\n\n    get event(): Function {\n        return this._event;\n    }\n\n    set tickInterval(interval: number) {\n        this.tickInterval = interval;\n    }\n\n    set event(func: Function) {\n        this.event = func;\n    }\n\n    bootstrap() {\n        if (this.event != null) {\n            let inter: number = this.tickInterval;\n            let max: number = this.tickInterval;\n            console.log(\"Registered\");\n            forever(function() {\n                if (inter > 0) {\n                    inter--;\n                } else {\n                    inter = max;\n                    this.event();\n                }\n            });\n        }\n    }\n}\n\nclass WhileInputHeldLoader {\n    _input: controller.Button;\n    _event: Function;\n\n    constructor (input: controller.Button, event: Function) {\n        this._input = input;\n        this._event = event;\n    }\n\n    get input(): controller.Button {\n        return this._input;\n    }\n\n    get event(): Function {\n        return this._event;\n    }\n\n    set input(additionalInput: controller.Button) {\n        this.input = additionalInput;\n    }\n\n    set event(func: Function) {\n        this.event = func;\n    }\n\n    bootstrap() {\n        if (this.event != null) {\n            let button = this.input;\n            console.log(\"Registered\");\n            forever(function() {\n                if (button.isPressed()) {\n                    this.event();\n                } else {\n                    this.event.stop();\n                }\n            });\n        }\n    }\n}\n\n\n\nlet test = new TickingLoader(40, testLoad);\ntest.bootstrap();\n\nfunction testLoad() {\n    console.log(\"did the thing\")\n}","pxt.json":"{\n    \"name\": \"Polyrosary\",\n    \"description\": \"\",\n    \"dependencies\": {\n        \"device\": \"*\",\n        \"browser-events\": \"*\"\n    },\n    \"files\": [\n        \"main.ts\",\n        \"README.md\",\n        \"assets.json\",\n        \"polyrosary.ts\"\n    ],\n    \"preferredEditor\": \"tsprj\",\n    \"languageRestriction\": \"javascript-only\"\n}\n"}}],"shares":[],"lastSaveTime":1773156524703}